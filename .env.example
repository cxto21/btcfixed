# BTCFixed – Environment Variables Template
# Copy to .env.local for local development
# Set these in Cloudflare Pages → Settings → Environment Variables for production

# ──────────────────────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────────────────────

# Starknet network: "sepolia" for testnet, "mainnet" for production
VITE_STARKNET_NETWORK=sepolia

# ──────────────────────────────────────────────────────────────
# OPTIONAL (defaults are public free RPCs — fine for dev/MVP)
# ──────────────────────────────────────────────────────────────

# Custom Starknet RPC endpoint.
# Free options:
#   Sepolia:  https://free-rpc.nethermind.io/sepolia-juno/
#   Mainnet:  https://free-rpc.nethermind.io/mainnet-juno/
# Paid options (better rate limits):
#   Infura:   https://starknet-sepolia.infura.io/v3/YOUR_KEY
#   Alchemy:  https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_7/YOUR_KEY
# VITE_STARKNET_RPC_URL=

# ──────────────────────────────────────────────────────────────
# SESSION 9 – Gasless Transactions (AVNU Paymaster)
# ──────────────────────────────────────────────────────────────
# VITE_AVNU_API_KEY=

# ──────────────────────────────────────────────────────────────
# SESSION 9 – Privy (Email/Social login)
# ──────────────────────────────────────────────────────────────
# VITE_PRIVY_APP_ID=
